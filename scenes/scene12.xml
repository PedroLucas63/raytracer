<RT3>
    <lookat look_from="10 10 -5" look_at="-2 0 10" up="0 1 0" />
    <camera type="perspective" fovy="30" screen_window="-6 6 -3.5 3.5" />
    <film type="image" w_res="1280" h_res="720" filename="output/scene12.png" img_type="png" />
    <integrator type="flat" />

    <world_begin/>
        <background type="single_color" color="242 242 242"/>

        <material name="green" type="flat" color="0 180 70"/>
        <material name="blue" type="flat" color="40 90 255"/>
        <material name="cyan" type="flat" color="0 210 220"/>
        <material name="magenta" type="flat" color="220 40 180"/>
        <material name="grid" type="grid" color1="123 123 123" color2="232 232 232" spacing="2"/>
        <material name="grid2" type="grid" color1="123 23 234" color2="13 233 78" spacing="0.5"/>

        <push_CTM/>
           <translate value="-2.2 3 3.5" />
           <scale value="2.2 2.2 2.2" />
           <object type="sphere" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="-2.2 3 6.5" />
           <scale value="1.2 1.2 1.2" />
           <object type="sphere" material="blue" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="2.2 2 3.5" />
           <scale value="0.95 0.95 0.95" />
           <object type="sphere" material="cyan" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="2.2 2 6.0" />
           <scale value="2.0 2.0 2.0" />
           <object type="sphere" material="magenta" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0 0 0" />
           <object type="plane" material="grid" />
        <pop_CTM/>
    <world_end/>
</RT3>
