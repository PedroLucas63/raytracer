<RT3>
    <!-- Camera matching scene 28 -->
    <lookat look_from="-5 7 -12" look_at="0 1 1" up="0 1 0" />
    <camera type="perspective" fovy="45" /> 
    
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="output/scene28.1.png" img_type="png" gamma_corrected="false" />

    <!-- The Scene -->
    <world_begin/>

        <!-- The Background -->
        <background type="4_colors" bl="176 214 175" tl="4 99 202" tr="4 99 202" br="176 214 175" />

        <!-- Lights -->
        <light_source type="ambient" I="0.1 0.1 0.1" scale="0.5 0.5 0.5" />
        
        <!-- over green shape -->
        <light_source type="spot" I="0.9 0.9 0.9" scale="1 1 1" from="-2 8 2" to="-2 2 3" cutoff="30" falloff="15" />
        <!-- over blue shape -->
        <light_source type="spot" I="0.9 0.9 0.9" scale="1 1 1" from="2 5 -1" to="2 2 -2" cutoff="25" falloff="25" />
        <!-- over red shape -->
        <light_source type="spot" I="0.9 0.2 0.2" scale="1 1 1" from="0 7 -1" to="0 2 0" cutoff="30" falloff="30" />
        <!-- over golden shape -->
        <light_source type="spot" I="1.0 0.65 0"  scale="1 1 1" from="15 12 -2" to="3 3 7" cutoff="15" falloff="5" />

        <!-- Materials -->
        <material name="floor" type="blinn" diffuse="0.2 0.2 0.2" specular="0.1 0.1 0.1" ambient="0.02 0.02 0.02" glossiness="10"/>

        <!-- Material Library -->
        <make_named_material type="blinn" name="gold"     ambient="0.4 0.4 0.4" diffuse ="1 0.65 0.0"   specular ="0.8 0.6 0.2"  glossiness ="256"/>
        <make_named_material type="blinn" name="grey"     ambient="0.1 0.1 0.1" diffuse ="0.7 0.7 0.7"  specular ="0 0 0"        glossiness ="0"/>
        <make_named_material type="blinn" name="redish"   ambient="0.6 0.6 0.6" diffuse ="0.9 0.2 0.1"  specular ="0.8 0.8 0.8"  glossiness ="64"/>
        <make_named_material type="blinn" name="greenish" ambient="0.6 0.6 0.6" diffuse ="0.2 0.9 0.2"  specular ="0.8 0.8 0.8"  glossiness ="256"/>
        <make_named_material type="blinn" name="blueish"  ambient="0.6 0.6 0.6" diffuse ="0.1 0.2 0.9"  specular ="0.8 0.8 0.8"  glossiness ="16"/>
        
        <named_material name="redish"/>
        <object type="cube" first_point="-1 0 -1" second_point="1 2 1" />

        <named_material name="greenish"/>
        <object type="cube" first_point="-3 0 2" second_point="-1 2 4" />

        <named_material name="blueish"/>
        <object type="cube" first_point="1 0 -3" second_point="3 2 -1" />

        <named_material name="gold"/>
        <object type="cube" first_point="1 0 5" second_point="5 3.4 9" />

        <named_material name="grey"/>
        <object type="plane" origin="0 0 0" norm="0 1 0" material="floor" />

    <world_end/>
</RT3>
