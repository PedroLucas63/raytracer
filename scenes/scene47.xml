<RT3>
   <lookat look_from="15 12 0" look_at="0 5 0" up="0 1 0" />
   <camera type="perspective" fovy="45" />
   <integrator type="blinn_phong" depth="2" />
   <film type="image" w_res="900" h_res="700" filename="output/scene47.png" img_type="png" />
   <aggregator type="lbvh" split_method="middle" max_prims_per_node="4" />

   <world_begin/>
      <background type="single_color" color="245 245 245"/>
      <make_named_material type="blinn" name="stone" ambient="0.03 0.03 0.03" diffuse="0.22 0.22 0.22" specular="0.05 0.05 0.05" glossiness="8" />

      <make_named_material type="flat" color="0.95 0.05 0.05" name="red" />

      <make_named_material
         name="metal"
         type="blinn"
         diffuse="0.05 0.05 0.05"
         specular="0.3 0.3 0.6" 
         ambient="0.5 0.5 0.8"
         glossiness="512"
         mirror="0.7 0.7 0.7"
      />
      
      <light_source type="point" from="5 15 15" I="0.9 0.9 0.9" attenuation="1 0 0" />
      <light_source type="point" from="0 3 0" I="0.9 0.9 0.9" attenuation="0.2 0 0" />
      <light_source type="directional" from="0 20 0" to="0 0 7" I="0.8 0.5 1" attenuation="0.2 0 0" world_radius="50" />

      <push_CTM/>
         <translate value="0 -10 0" />
         <object type="plane" material="stone" />
      <pop_CTM/>

      <push_CTM/>
         <translate value="0 0 25" />
         <rotate axis="1.0 0 0" angle="90" />
         <object type="plane" material="stone" />
      <pop_CTM/>

      <object type="trianglemesh"
         filename="scenes/obj/body.obj"
         compute_normals="false"
         backface_cull="false"
         material="metal"
      />
   <world_end/>
</RT3>
