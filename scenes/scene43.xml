<RT3>
   <lookat look_from="0 1 -6" look_at="0 0 0" up="0 1 0" />
   <camera type="perspective" fovy="45" />
   <integrator type="blinn_phong" depth="1" />
   <film type="image" w_res="900" h_res="600" filename="output/scene43.png" img_type="png" />

   <world_begin/>
      <background type="single_color" color="230 230 230"/>

      <material
         name="green"
         type="blinn"
         diffuse="0.15 0.60 0.25"
         specular="0.15 0.15 0.15"
         ambient="0.03 0.03 0.03"
         glossiness="60"
      />
      <material
         name="orange"
         type="blinn"
         diffuse="0.85 0.45 0.10"
         specular="0.20 0.20 0.20"
         ambient="0.03 0.03 0.03"
         glossiness="70"
      />

      <light_source type="point" from="-3 4 -4" I="0.9 0.9 0.9" />
      <light_source type="directional" from="3 5 -6" to="0 0 0" I="0.4 0.4 0.4" world_radius="50" />

      <!-- Floor quad (XZ plane) -->
      <object
         type="trianglemesh"
         material="green"
         backface_cull="true"
         indices="0 2 1 0 3 2"
         vertices="
            -2 -1 -1
            2 -1 -1
            2 -1  2
            -2 -1  2
         "
         uv="
            0 0
            1 0
            1 1
            0 1
         "
      />

      <!-- Wall quad (XY plane) -->
      <object
         type="trianglemesh"
         material="orange"
         backface_cull="true"
         indices="0 2 1 0 3 2"
         vertices="
            -2 -1  1
             2 -1  1
             2  2  1
            -2  2  1
         "
         uv="
            0 0
            1 0
            1 1
            0 1
         "
      />
   <world_end/>
</RT3>
