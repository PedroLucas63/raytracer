
<RT3>
    <lookat look_from="0 5 -10" look_at="0 0 5" up="0 1 0" />
    <camera type="perspective" fovy="45" /> 
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1920" h_res="1200" filename="output/scene30.png" img_type="png" gamma_corrected="false" />

    <!-- The Scene -->
    <world_begin/>

        <!-- The Background -->
        <background type="4_colors" bl="176 214 175" tl="4 99 202" tr="4 99 202" br="176 214 175" />

        <!-- Lights -->
        <light_source type="ambient" I="0.1 0.1 0.1" scale="0.5 0.5 0.5" />
        <light_source type="spot" I="0.9 0.9 0.9" scale="1 1 1" from="0 10 0" to="0 2 0" cutoff="30" falloff="15" />

        <!-- Material Library -->
        <material type="blinn" name="redish" ambient="0.6 0.6 0.6" diffuse ="0.9 0.2 0.1"  specular ="0.8 0.8 0.8"  glossiness ="64"/>
        <material type="blinn" name="floor" diffuse="0.2 0.2 0.2" specular="0.1 0.1 0.1" ambient="0.02 0.02 0.02" glossiness="10"/>

        <!-- Objects -->
        <object type="sphere" center="0 1 0" radius="1" material="redish" />
        <object type="plane" origin="0 0 0" norm="0 1 0" material="floor" />
    <world_end/>
</RT3>
