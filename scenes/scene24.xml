    <!-- ═══════════════════════════════════════════════════════
         TEMPLO DE ESFERAS
         Câmera olhando de longe e levemente de cima para um
         conjunto de esferas dispostas como um templo grego:
         base plana, colunas de esferas e uma esfera central
         grande no topo.
    ═══════════════════════════════════════════════════════ -->

    <lookat look_from="-8 9 -14" look_at="0 2 0" up="0 1 0" />
    <camera type="perspective" fovy="42" />
    <integrator type="blinn_phong" depth="1" />
    <film type="image" w_res="1280" h_res="720"
          filename="output/scene24.png" img_type="png" />
          
    <world_begin/>

        <!-- ── Fundo escuro azulado ── -->
        <background type="single_color" color="0.01 0.01 0.04" />

        <!-- ══════════════ MATERIAIS ══════════════ -->

        <!-- Mármore branco: colunas e base -->
        <make_named_material type="blinn" name="marble"
            diffuse="0.85 0.83 0.80"
            specular="0.9 0.9 0.9"
            ambient="0.08 0.08 0.08"
            glossiness="128"/>

        <!-- Ouro: esfera central do topo -->
        <make_named_material type="blinn" name="gold"
            diffuse="1.0 0.72 0.05"
            specular="1.0 0.85 0.4"
            ambient="0.15 0.10 0.02"
            glossiness="512"/>

        <!-- Pedra escura: piso -->
        <make_named_material type="blinn" name="stone"
            diffuse="0.18 0.16 0.14"
            specular="0.05 0.05 0.05"
            ambient="0.04 0.04 0.04"
            glossiness="8"/>

        <!-- Rubi: esferas decorativas cantos -->
        <make_named_material type="blinn" name="ruby"
            diffuse="0.85 0.05 0.05"
            specular="1.0 0.7 0.7"
            ambient="0.12 0.01 0.01"
            glossiness="256"/>

        <!-- Safira: esferas decorativas meio -->
        <make_named_material type="blinn" name="sapphire"
            diffuse="0.05 0.15 0.90"
            specular="0.8 0.8 1.0"
            ambient="0.01 0.02 0.12"
            glossiness="256"/>

        <!-- Esmeralda -->
