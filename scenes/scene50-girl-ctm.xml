<RT3>
    <lookat look_from="0 2 2" look_at="0 0 0" up="0 0 1" />
    <camera type="perspective" fovy="45" />
    <film type="image" w_res="2560" h_res="1440" filename="output/scene50-girl.png" img_type="png" />
    <aggregator type="bvh" split_method="middle" max_prims_per_node="4" />
    <integrator type="blinn_phong" depth="5" />

    <world_begin/>
        <background type="single_color" color="242 242 242"/>

        <make_named_material type="blinn" name="ground" ambient="0.03 0.03 0.03" diffuse="0.22 0.22 0.22" specular="0.05 0.05 0.05" glossiness="8" />

        <material name="green" type="blinn"
            diffuse="0.2 0.95 0.2"
            specular="0.2 0.95 0.2"
            ambient="0.02 0.3 0.02"
            glossiness="1024"/>

        <material name="magenta" type="blinn"
            diffuse="0.6 0.2 0.6"
            specular="0.6 0.2 0.6"
            ambient="0.2 0.02 0.2"
            glossiness="1024"/>

        <material name="yellow" type="blinn"
            diffuse="0.6 0.4 0.05"
            specular="0.6 0.4 0.05"
            ambient="0.3 0.03 0.2"
            glossiness="1024"/>

        <material name="blue" type="blinn"
            diffuse="0.2 0.2 0.95"
            specular="0.2 0.2 0.95"
            ambient="0.02 0.02 0.3"
            glossiness="1024"/>

        <material name="metal-red" type="blinn"
            diffuse="0.7 0.1 0.1"
            specular="1 1 1"
            ambient="0.01 0.05 0.05"
            glossiness="512"
            mirror="0.7 0.7 0.7"/>

        <material name="mirror" type="blinn"
            diffuse="0.2 0.2 0.2"
            specular="0.2 0.2 0.2"
            ambient="0.02 0.02 0.02"
            glossiness="0"
            mirror="0.95 0.95 0.95"/>

        <light_source type="ambient" I="0.2 0.2 0.2" scale="3 3 3" />

        <light_source type="point" from="0 30 0"  I="1.0 1.0 1.0" attenuation="0.3 0 0"/>
        <light_source type="point" from="0 10 -25"  I="1.0 1.0 1.0" attenuation="0.3 0 0"/>
        <light_source type="directional" from="100 35 -30" to="0 0 0" I="1.0 1.0 1.0" attenuation="0.1 0 0" world_radius="50" />


        <object_instance_begin name="girl-set" />
            <push_CTM/>
                <scale value="10 10 10" />
                <rotate axis="0 1 0" angle="180.0"/>
                <include filename="scenes/references/girl.xml" />
            <pop_CTM/>
        <object_instance_end/>
    <world_end/>
</RT3>