<RT3>
   <lookat look_from="0 0 -20" look_at="0 0 5" up="0 1 0" />
   <camera type="perspective" fovy="35" screen_window="-4 4 -2.25 2.25" />
   <film type="image" w_res="1920" h_res="1080" filename="output/scene27.png" img_type="png" />
   <integrator type="blinn_phong" depth="3" />

   <world_begin/>

      <!-- HDRI -->
      <background type="image" filename="assets/images/beach.png" spherical="true" />

      <!-- Espelho forte -->
      <material name="mirror1" type="blinn"
         diffuse="0.05 0.05 0.05"
         specular="1 1 1"
         ambient="0.0 0.0 0.0"
         glossiness="512"
         reflectivity="0.95"/>

      <material name="mirror2" type="blinn"
         diffuse="0.05 0.05 0.05"
         specular="1 1 1"
         ambient="0.0 0.0 0.0"
         glossiness="512"
         reflectivity="0.9"/>

      <!-- Esfera mais “colorida” -->
      <material name="colorful" type="blinn"
         diffuse="0.2 0.4 0.8"
         specular="0.5 0.5 0.5"
         ambient="0.0 0.0 0.0"
         glossiness="64"
         reflectivity="0.3"/>

      <!-- Luzes -->
      <light_source type="directional"
         from="0 10 -10"
         to="0 0 5"
         I="1 1 1"/>
      <light_source type="ambient" I="0.1 0.1 0.1"/>

      <!-- Esferas grandes -->
      <object type="sphere" center="-3 -6 -2" radius="2.5" material="mirror1"/>
      <object type="sphere" center="3 -6 0" radius="2.5" material="mirror2"/>
      <object type="sphere" center="0 -6 -4" radius="2.0" material="colorful"/>

   <world_end/>
</RT3>