<RT3>
   <lookat look_from="0 0 -20" look_at="0 0 5" up="0 1 0" />
   <camera type="perspective" fovy="35" screen_window="-4 4 -2.25 2.25" />
   <film type="image" w_res="1920" h_res="1080" filename="output/scene27.png" img_type="png" />
   <integrator type="blinn_phong" depth="3" />

   <world_begin/>

      <!-- HDRI -->
      <background type="image" filename="assets/images/beach.png" spherical="true" />

      <!-- Espelho forte -->
      <material name="mirror1" type="blinn"
         diffuse="0.05 0.05 0.05"
         specular="1 1 1"
         ambient="0.0 0.0 0.0"
         glossiness="512"
         mirror="0.95 0.95 0.95"/>

      <material name="mirror2" type="blinn"
         diffuse="0.05 0.05 0.05"
         specular="1 1 1"
         ambient="0.0 0.0 0.0"
         glossiness="512"
         mirror="0.9 0.9 0.9"/>

      <!-- Esfera mais “colorida” -->
      <material name="colorful" type="blinn"
         diffuse="0.2 0.4 0.8"
         specular="0.5 0.5 0.5"
         ambient="0.0 0.0 0.0"
         glossiness="64"
         mirror="0.3 0.3 0.3"/>

      <!-- Luzes -->
      <light_source type="directional"
         from="0 10 -10"
         to="0 0 5"
         I="1 1 1"/>
      <light_source type="ambient" I="0.1 0.1 0.1"/>

      <!-- Esferas grandes -->
      <push_CTM/>
         <translate value="-3 -6 -2" />
         <scale value="2.5 2.5 2.5" />
         <object type="sphere" material="mirror1" />
      <pop_CTM/>
      <push_CTM/>
         <translate value="3 -6 0" />
         <scale value="2.5 2.5 2.5" />
         <object type="sphere" material="mirror2" />
      <pop_CTM/>
      <push_CTM/>
         <translate value="0 -6 -4" />
         <scale value="2.0 2.0 2.0" />
         <object type="sphere" material="colorful" />
      <pop_CTM/>

   <world_end/>
</RT3>