<RT3>
    <lookat look_from="0 35 10" look_at="0 3 5" up="0 0 1" />
    <camera type="perspective" fovy="45" />
    <film type="image" w_res="2560" h_res="1440" filename="output/scene48.png" img_type="png" />
    <integrator type="blinn_phong" depth="5" />

    <world_begin/>
        <background type="single_color" color="242 242 242"/>

        <material name="green" type="blinn"
            diffuse="0.2 0.95 0.2"
            specular="0.2 0.95 0.2"
            ambient="0.02 0.3 0.02"
            glossiness="1024"/>

        <material name="magenta" type="blinn"
            diffuse="0.6 0.2 0.6"
            specular="0.6 0.2 0.6"
            ambient="0.2 0.02 0.2"
            glossiness="1024"/>

        <material name="yellow" type="blinn"
            diffuse="0.6 0.4 0.05"
            specular="0.6 0.4 0.05"
            ambient="0.3 0.03 0.2"
            glossiness="1024"/>

        <material name="blue" type="blinn"
            diffuse="0.2 0.2 0.95"
            specular="0.2 0.2 0.95"
            ambient="0.02 0.02 0.3"
            glossiness="1024"/>

        <material name="metal" type="blinn"
            diffuse="0.05 0.05 0.05"
            specular="1 1 1"
            ambient="0.02 0.02 0.02"
            glossiness="512"
            mirror="0.7 0.7 0.7"/>

        <material name="mirror" type="blinn"
            diffuse="0.2 0.2 0.2"
            specular="0.2 0.2 0.2"
            ambient="0.02 0.02 0.02"
            glossiness="0"
            mirror="0.95 0.95 0.95"/>

        <light_source type="ambient" I="0.1 0.1 0.1" scale="3 3 3" />
        <!-- Luzes posicionadas no espaço world, acima do teapot em Y -->
        <light_source type="point" from="0 20 5"  I="1.0 1.0 1.0" attenuation="1 0 0"/>
        <light_source type="point" from="5 18 8"  I="0.7 0.7 0.7" attenuation="1 0 0"/>
        <light_source type="point" from="-5 18 8" I="0.7 0.7 0.7" attenuation="1 0 0"/>

        <!-- CHÃO: plano em Z, pois a câmera vê Z como "baixo" -->
        <object type="plane" origin="0 0 -15" norm="0 0 1" material="mirror" />

        <!-- TETO: acima em Z -->
        <object type="plane" origin="0 0 25" norm="0 0 -1" material="mirror" />

        <!-- PAREDE DE FUNDO (longe da câmera em Y) -->
        <object type="plane" origin="0 -25 0" norm="0 1 0" material="mirror" />

        <!-- PAREDE ESQUERDA -->
        <object type="plane" origin="-20 0 0" norm="1 0 0" material="mirror" />

        <!-- PAREDE DIREITA -->
        <object type="plane" origin="20 0 0" norm="-1 0 0" material="mirror" />

        <object type="trianglemesh"
                filename="scenes/obj/teapot-low.obj"
                compute_normals="false"
                backface_cull="false"
                material="metal"
        />

    <world_end/>
</RT3>