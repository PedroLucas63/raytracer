<RT3>
    <lookat look_from="0 0 -10" look_at="0 0 4" up="0 1 0" />
    <camera type="orthographic" screen_window="-6 6 -3.5 3.5" />
    <film type="image" w_res="1280" h_res="720" filename="output/scene10.png" img_type="png" />
    <integrator type="flat" />

    <world_begin/>
        <background type="single_color" color="242 242 242"/>

        <material name="green" type="flat" color="0 180 70"/>
        <material name="blue" type="flat" color="40 90 255"/>
        <material name="cyan" type="flat" color="0 210 220"/>
        <material name="magenta" type="flat" color="220 40 180"/>

        <!-- Pair 1: smaller front sphere showing contour of the back sphere -->
        <push_CTM/>
           <translate value="2.2 0 6.0" />
           <scale value="2.0 2.0 2.0" />
           <object type="sphere" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="2.2 0 3.5" />
           <scale value="0.95 0.95 0.95" />
           <object type="sphere" material="cyan" />
        <pop_CTM/>

        <!-- Pair 2: larger front sphere occluding the back sphere -->
        <push_CTM/>
           <translate value="-2.2 0 3.5" />
           <scale value="2.2 2.2 2.2" />
           <object type="sphere" material="green" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="-2.2 0 6.0" />
           <scale value="1.2 1.2 1.2" />
           <object type="sphere" material="blue" />
        <pop_CTM/>


    <world_end/>
</RT3>
