<RT3>
    <!-- Robot made from boxs, spheres, and planes -->
    <lookat look_from="0 6 -16" look_at="0 4 2" up="0 1 0" />
    <camera type="perspective" fovy="38" />
    <film type="image" w_res="1920" h_res="1080" filename="output/scene40.png" img_type="png" gamma_corrected="false" />
    <integrator type="blinn_phong" depth="3" />

    <world_begin/>
        <background type="4_colors" bl="230 230 240" tl="10 60 160" tr="10 60 160" br="230 230 240" />

        <light_source type="ambient" I="0.1 0.1 0.1" scale="1 1 1" />
        <light_source type="point" from="-6 10 -6" I="1.0 1.0 1.0" attenuation="1 0 0" />
        <light_source type="spot" from="6 12 -4" to="0 4 0" I="0.9 0.9 0.9" cutoff="30" falloff="20" />
        <light_source type="spot" from="0 9 8" to="0 5 2" I="0.7 0.7 0.9" cutoff="25" falloff="15" />

        <make_named_material type="blinn" name="metal_light" ambient="0.2 0.2 0.2" diffuse="0.7 0.75 0.8" specular="0.9 0.9 0.9" glossiness="256" />
        <make_named_material type="blinn" name="metal_dark" ambient="0.1 0.1 0.1" diffuse="0.25 0.28 0.3" specular="0.6 0.6 0.6" glossiness="64" />
        <make_named_material type="blinn" name="accent_red" ambient="0.3 0.05 0.05" diffuse="0.8 0.2 0.2" specular="0.8 0.8 0.8" glossiness="128" />
        <make_named_material type="blinn" name="accent_blue" ambient="0.05 0.05 0.3" diffuse="0.2 0.3 0.9" specular="0.8 0.8 0.8" glossiness="128" />
        <make_named_material type="blinn" name="ground" ambient="0.03 0.03 0.03" diffuse="0.25 0.25 0.25" specular="0.05 0.05 0.05" glossiness="8" />
        <make_named_material type="blinn" name="accent_yellow" ambient="0.3 0.3 0.05" diffuse="0.9 0.8 0.2" specular="0.8 0.8 0.8" glossiness="64" />
        <make_named_material type="blinn" name="accent_green" ambient="0.05 0.3 0.05" diffuse="0.2 0.8 0.2" specular="0.8 0.8 0.8" glossiness="128" />

        <!-- Ground and back wall -->
        <push_CTM/>
           <translate value="0 0 0" />
           <object type="plane" material="ground" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0 0 12" />
           <rotate axis="1.000000 0.000000 -0.000000" angle="90.000000" />
           <object type="plane" material="ground" />
        <pop_CTM/>

        <!-- Torso -->
        <named_material name="metal_light" />
        <push_CTM/>
           <translate value="0.000000 3.700000 0.000000" />
           <scale value="3.200000 3.000000 1.200000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="0.000000 3.850000 0.825000" />
           <scale value="2.700000 1.900000 0.350000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="accent_green" />
        <push_CTM/>
           <translate value="-0.9 3.3 1.05" />
           <scale value="0.18 0.18 0.18" />
           <object type="sphere" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="-0.4 3.3 1.05" />
           <scale value="0.18 0.18 0.18" />
           <object type="sphere" />
        <pop_CTM/>
        <named_material name="accent_red" />
        <push_CTM/>
           <translate value="0.1 3.3 1.05" />
           <scale value="0.18 0.18 0.18" />
           <object type="sphere" />
        <pop_CTM/>
        <named_material name="accent_blue" />
        <push_CTM/>
           <translate value="0.6 3.3 1.05" />
           <scale value="0.18 0.18 0.18" />
           <object type="sphere" />
        <pop_CTM/>
        <named_material name="accent_yellow" />
        <push_CTM/>
           <translate value="0.000000 4.275000 1.035000" />
           <scale value="1.800000 0.350000 0.170000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="accent_blue" />
        <push_CTM/>
           <translate value="0.0 3.9 1.2" />
           <scale value="0.22 0.22 0.22" />
           <object type="sphere" />
        <pop_CTM/>

        <!-- Head -->
        <named_material name="metal_light" />
        <push_CTM/>
           <translate value="0.000000 6.200000 0.000000" />
           <scale value="2.000000 1.600000 1.400000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="0.000000 6.175000 0.850000" />
           <scale value="1.900000 0.950000 0.260000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="accent_blue" />
        <push_CTM/>
           <translate value="-0.45 6.35 1.05" />
           <scale value="0.22 0.22 0.22" />
           <object type="sphere" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0.45 6.35 1.05" />
           <scale value="0.22 0.22 0.22" />
           <object type="sphere" />
        <pop_CTM/>
        <named_material name="accent_red" />
        <push_CTM/>
           <translate value="0.000000 5.975000 0.990000" />
           <scale value="1.400000 0.350000 0.180000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="-0.450000 5.960000 1.130000" />
           <scale value="0.300000 0.120000 0.100000" />
           <object type="box" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0.000000 5.960000 1.130000" />
           <scale value="0.300000 0.120000 0.100000" />
           <object type="box" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0.450000 5.960000 1.130000" />
           <scale value="0.300000 0.120000 0.100000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="accent_yellow" />
        <push_CTM/>
           <translate value="-0.75 6.7 1.0" />
           <scale value="0.12 0.12 0.12" />
           <object type="sphere" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0.75 6.7 1.0" />
           <scale value="0.12 0.12 0.12" />
           <object type="sphere" />
        <pop_CTM/>

        <!-- Neck -->
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="0.000000 5.300000 0.000000" />
           <scale value="0.600000 0.400000 0.600000" />
           <object type="box" />
        <pop_CTM/>

        <!-- Arms -->
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="-2.300000 3.900000 0.000000" />
           <scale value="1.400000 0.600000 0.800000" />
           <object type="box" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="2.300000 3.900000 0.000000" />
           <scale value="1.400000 0.600000 0.800000" />
           <object type="box" />
        <pop_CTM/>
        <named_material name="metal_light" />
        <push_CTM/>
           <translate value="-3.2 3.9 0" />
           <scale value="0.35 0.35 0.35" />
           <object type="sphere" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="3.2 3.9 0" />
           <scale value="0.35 0.35 0.35" />
           <object type="sphere" />
        <pop_CTM/>

        <!-- Hands -->
        <named_material name="accent_blue" />
        <push_CTM/>
           <translate value="-3.450000 3.550000 0.000000" />
           <scale value="0.700000 0.700000 1.000000" />
           <object type="box" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="3.450000 3.550000 0.000000" />
           <scale value="0.700000 0.700000 1.000000" />
           <object type="box" />
        <pop_CTM/>

        <!-- Hips -->
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="0.000000 1.900000 0.000000" />
           <scale value="2.800000 0.600000 1.000000" />
           <object type="box" />
        <pop_CTM/>

        <!-- Legs -->
        <named_material name="metal_light" />
        <push_CTM/>
           <translate value="-0.700000 0.900000 0.000000" />
           <scale value="1.000000 1.400000 0.800000" />
           <object type="box" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0.700000 0.900000 0.000000" />
           <scale value="1.000000 1.400000 0.800000" />
           <object type="box" />
        <pop_CTM/>

        <!-- Feet -->
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="-0.850000 0.150000 -0.200000" />
           <scale value="1.500000 0.300000 1.800000" />
           <object type="box" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="0.850000 0.150000 -0.200000" />
           <scale value="1.500000 0.300000 1.800000" />
           <object type="box" />
        <pop_CTM/>

        <!-- Shoulder plates -->
        <named_material name="accent_red" />
        <push_CTM/>
           <translate value="-1.800000 4.550000 0.000000" />
           <scale value="0.800000 0.500000 1.600000" />
           <object type="box" />
        <pop_CTM/>
        <push_CTM/>
           <translate value="1.800000 4.550000 0.000000" />
           <scale value="0.800000 0.500000 1.600000" />
           <object type="box" />
        <pop_CTM/>

        <!-- Antenna -->
        <named_material name="accent_blue" />
        <push_CTM/>
           <translate value="0 7.4 0" />
           <scale value="0.18 0.18 0.18" />
           <object type="sphere" />
        <pop_CTM/>
        <named_material name="metal_dark" />
        <push_CTM/>
           <translate value="0.000000 7.175000 0.000000" />
           <scale value="0.160000 0.350000 0.160000" />
           <object type="box" />
        <pop_CTM/>
    <world_end/>
</RT3>
