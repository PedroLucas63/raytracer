<RT3>
    <!-- Robot made from boxs, spheres, and planes -->
    <lookat look_from="0 6 -16" look_at="0 4 2" up="0 1 0" />
    <camera type="perspective" fovy="38" />
    <film type="image" w_res="1920" h_res="1080" filename="output/scene40.png" img_type="png" gamma_corrected="false" />
    <integrator type="blinn_phong" depth="3" />

    <world_begin/>
        <background type="4_colors" bl="230 230 240" tl="10 60 160" tr="10 60 160" br="230 230 240" />

        <light_source type="ambient" I="0.1 0.1 0.1" scale="1 1 1" />
        <light_source type="point" from="-6 10 -6" I="1.0 1.0 1.0" attenuation="1 0 0" />
        <light_source type="spot" from="6 12 -4" to="0 4 0" I="0.9 0.9 0.9" cutoff="30" falloff="20" />
        <light_source type="spot" from="0 9 8" to="0 5 2" I="0.7 0.7 0.9" cutoff="25" falloff="15" />

        <make_named_material type="blinn" name="metal_light" ambient="0.2 0.2 0.2" diffuse="0.7 0.75 0.8" specular="0.9 0.9 0.9" glossiness="256" />
        <make_named_material type="blinn" name="metal_dark" ambient="0.1 0.1 0.1" diffuse="0.25 0.28 0.3" specular="0.6 0.6 0.6" glossiness="64" />
        <make_named_material type="blinn" name="accent_red" ambient="0.3 0.05 0.05" diffuse="0.8 0.2 0.2" specular="0.8 0.8 0.8" glossiness="128" />
        <make_named_material type="blinn" name="accent_blue" ambient="0.05 0.05 0.3" diffuse="0.2 0.3 0.9" specular="0.8 0.8 0.8" glossiness="128" />
        <make_named_material type="blinn" name="ground" ambient="0.03 0.03 0.03" diffuse="0.25 0.25 0.25" specular="0.05 0.05 0.05" glossiness="8" />
        <make_named_material type="blinn" name="accent_yellow" ambient="0.3 0.3 0.05" diffuse="0.9 0.8 0.2" specular="0.8 0.8 0.8" glossiness="64" />
        <make_named_material type="blinn" name="accent_green" ambient="0.05 0.3 0.05" diffuse="0.2 0.8 0.2" specular="0.8 0.8 0.8" glossiness="128" />

        <!-- Ground and back wall -->
        <object type="plane" origin="0 0 0" norm="0 1 0" material="ground" />
        <object type="plane" origin="0 0 12" norm="0 0 1" material="ground" />

        <!-- Torso -->
        <named_material name="metal_light" />
        <object type="box" first_point="-1.6 2.2 -0.6" second_point="1.6 5.2 0.6" />
        <named_material name="metal_dark" />
        <object type="box" first_point="-1.35 2.9 0.65" second_point="1.35 4.8 1.0" />
        <named_material name="accent_green" />
        <object type="sphere" center="-0.9 3.3 1.05" radius="0.18" />
        <object type="sphere" center="-0.4 3.3 1.05" radius="0.18" />
        <named_material name="accent_red" />
        <object type="sphere" center="0.1 3.3 1.05" radius="0.18" />
        <named_material name="accent_blue" />
        <object type="sphere" center="0.6 3.3 1.05" radius="0.18" />
        <named_material name="accent_yellow" />
        <object type="box" first_point="-0.9 4.1 0.95" second_point="0.9 4.45 1.12" />
        <named_material name="accent_blue" />
        <object type="sphere" center="0.0 3.9 1.2" radius="0.22" />

        <!-- Head -->
        <named_material name="metal_light" />
        <object type="box" first_point="-1.0 5.4 -0.7" second_point="1.0 7.0 0.7" />
        <named_material name="metal_dark" />
        <object type="box" first_point="-0.95 5.7 0.72" second_point="0.95 6.65 0.98" />
        <named_material name="accent_blue" />
        <object type="sphere" center="-0.45 6.35 1.05" radius="0.22" />
        <object type="sphere" center="0.45 6.35 1.05" radius="0.22" />
        <named_material name="accent_red" />
        <object type="box" first_point="-0.7 5.8 0.9" second_point="0.7 6.15 1.08" />
        <named_material name="metal_dark" />
        <object type="box" first_point="-0.6 5.9 1.08" second_point="-0.3 6.02 1.18" />
        <object type="box" first_point="-0.15 5.9 1.08" second_point="0.15 6.02 1.18" />
        <object type="box" first_point="0.3 5.9 1.08" second_point="0.6 6.02 1.18" />
        <named_material name="accent_yellow" />
        <object type="sphere" center="-0.75 6.7 1.0" radius="0.12" />
        <object type="sphere" center="0.75 6.7 1.0" radius="0.12" />

        <!-- Neck -->
        <named_material name="metal_dark" />
        <object type="box" first_point="-0.3 5.1 -0.3" second_point="0.3 5.5 0.3" />

        <!-- Arms -->
        <named_material name="metal_dark" />
        <object type="box" first_point="-3.0 3.6 -0.4" second_point="-1.6 4.2 0.4" />
        <object type="box" first_point="1.6 3.6 -0.4" second_point="3.0 4.2 0.4" />
        <named_material name="metal_light" />
        <object type="sphere" center="-3.2 3.9 0" radius="0.35" />
        <object type="sphere" center="3.2 3.9 0" radius="0.35" />

        <!-- Hands -->
        <named_material name="accent_blue" />
        <object type="box" first_point="-3.8 3.2 -0.5" second_point="-3.1 3.9 0.5" />
        <object type="box" first_point="3.1 3.2 -0.5" second_point="3.8 3.9 0.5" />

        <!-- Hips -->
        <named_material name="metal_dark" />
        <object type="box" first_point="-1.4 1.6 -0.5" second_point="1.4 2.2 0.5" />

        <!-- Legs -->
        <named_material name="metal_light" />
        <object type="box" first_point="-1.2 0.2 -0.4" second_point="-0.2 1.6 0.4" />
        <object type="box" first_point="0.2 0.2 -0.4" second_point="1.2 1.6 0.4" />

        <!-- Feet -->
        <named_material name="metal_dark" />
        <object type="box" first_point="-1.6 0 -1.1" second_point="-0.1 0.3 0.7" />
        <object type="box" first_point="0.1 0 -1.1" second_point="1.6 0.3 0.7" />

        <!-- Shoulder plates -->
        <named_material name="accent_red" />
        <object type="box" first_point="-2.2 4.3 -0.8" second_point="-1.4 4.8 0.8" />
        <object type="box" first_point="1.4 4.3 -0.8" second_point="2.2 4.8 0.8" />

        <!-- Antenna -->
        <named_material name="accent_blue" />
        <object type="sphere" center="0 7.4 0" radius="0.18" />
        <named_material name="metal_dark" />
        <object type="box" first_point="-0.08 7.0 -0.08" second_point="0.08 7.35 0.08" />
    <world_end/>
</RT3>
