<RT3>
    <lookat look_from="0 15 -50" look_at="0 0 5" up="0 1 0" />
    <camera type="perspective" fovy="40" screen_window="-1 1 -0.56 0.56" />
    <film type="image" w_res="1280" h_res="720" filename="output/scene23.png" img_type="png" />
    <integrator type="blinn_phong" />

    <world_begin/>
        <background type="single_color" color="0.01 0.01 0.02"/>

        <material name="m1" type="blinn" diffuse="0.8 0.1 0.1" specular="1 1 1" ambient="0.1 0.1 0.1" glossiness="256"/>
        <material name="m2" type="blinn" diffuse="0.1 0.8 0.1" specular="1 1 1" ambient="0.1 0.1 0.1" glossiness="256"/>
        <material name="m3" type="blinn" diffuse="0.1 0.1 0.8" specular="1 1 1" ambient="0.1 0.1 0.1" glossiness="256"/>
        <material name="m4" type="blinn" diffuse="0.8 0.8 0.1" specular="1 1 1" ambient="0.1 0.1 0.1" glossiness="256"/>
        <material name="m5" type="blinn" diffuse="0.8 0.1 0.8" specular="1 1 1" ambient="0.1 0.1 0.1" glossiness="256"/>
        
        <material name="floor" type="blinn" diffuse="0.2 0.2 0.2" specular="0.1 0.1 0.1" ambient="0.02 0.02 0.02" glossiness="10"/>

        <light_source type="point" from="0 2 5" I="0.5 0.5 1.0"/>
        <light_source type="directional" from="10 10 -5" to="-2 0 10" I="1.0 1.0 1.0" world_radius="50"/>
        <light_source type="ambient" I="0.1 0.1 0.1"  scale="4 4 4" />


        <push_CTM/>
           <translate value="0.000000 1.000000 0.000000" />
           <scale value="2.000000 2.000000 2.000000" />
           <object type="box" material="m1" />
        <pop_CTM/>

        <push_CTM/>
           <translate value="-2.000000 1.000000 3.000000" />
           <scale value="2.000000 2.000000 2.000000" />
           <object type="box" material="m2" />
        <pop_CTM/>

        <push_CTM/>
           <translate value="2.000000 1.000000 -2.000000" />
           <scale value="2.000000 2.000000 2.000000" />
           <object type="box" material="m3" />
        <pop_CTM/>

        <push_CTM/>
           <translate value="3.000000 1.700000 7.000000" />
           <scale value="4.000000 3.400000 4.000000" />
           <object type="box" material="m4" />
        <pop_CTM/>

        <push_CTM/>
           <translate value="0 0 0" />
           <object type="plane" material="floor" />
        <pop_CTM/>
    <world_end/>
</RT3>